<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Downlodip — Admin</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="admin-page">

<div class="admin-container">
  <header class="admin-header">
    <h1>Downlodip <span>Admin</span></h1>
    <p>Manage device-agnostic link campaigns</p>
  </header>

  <div class="card" id="auth-card">
    <label>Admin Secret</label>
    <div class="input-row">
      <input type="password" id="admin-secret" placeholder="Enter your admin secret" value="<%= secret %>"/>
      <button onclick="loadCampaigns()">Load Campaigns</button>
    </div>
  </div>

  <div class="card">
    <h2>New Campaign</h2>
    <div class="form-grid">
      <div class="field">
        <label>Campaign Name</label>
        <input type="text" id="f-name" placeholder="e.g. Movie Download April"/>
      </div>
      <div class="field">
        <label>Resolver Type</label>
        <select id="f-type" onchange="updateResolverHelp()">
          <option value="url_template">URL Template</option>
          <option value="api_fetch">API Fetch</option>
          <option value="regex_scrape">Regex Scrape</option>
          <option value="static">Static URL</option>
        </select>
      </div>
      <div class="field full">
        <label>Resolver Config <span id="resolver-hint" class="hint"></span></label>
        <textarea id="f-config" rows="4" placeholder="{}"></textarea>
      </div>
      <div class="field full">
        <label class="checkbox-label">
          <input type="checkbox" id="f-lander"/> Show lander page (user clicks button to get link)
        </label>
      </div>
      <div id="lander-fields" style="display:none" class="field full sub-grid">
        <div class="field">
          <label>Lander Title</label>
          <input type="text" id="f-lander-title" placeholder="Download Now"/>
        </div>
        <div class="field">
          <label>Lander Description</label>
          <input type="text" id="f-lander-desc" placeholder="Click the button below to get your download link."/>
        </div>
      </div>
    </div>
    <button class="btn-primary" onclick="createCampaign()">Create Campaign</button>
  </div>

  <div class="card">
    <h2>Campaigns</h2>
    <div id="campaigns-list"><p class="muted">Load campaigns above to see them here.</p></div>
  </div>

  <div id="stats-modal" class="modal hidden">
    <div class="modal-box">
      <button class="modal-close" onclick="closeStats()">✕</button>
      <h2 id="stats-title">Stats</h2>
      <div id="stats-content"></div>
    </div>
  </div>
</div>

<script src="/js/admin.js"></script>
</body>
</html>
