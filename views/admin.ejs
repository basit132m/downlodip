<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Downlodip — Admin</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="admin-page">

<div class="admin-container">
  <header class="admin-header">
    <div style="display:flex;justify-content:space-between;align-items:center;">
      <div>
        <h1>Downlodip <span>Admin</span></h1>
        <p>Device-agnostic link manager</p>
      </div>
      <a href="/admin/logout" class="btn-danger" style="text-decoration:none;">Logout</a>
    </div>
  </header>

  <!-- ── Quick Link Creator ── -->
  <div class="card">
    <h2>➕ Create Shareable Link</h2>
    <p class="muted" style="margin-bottom:18px;">Paste a URL, give it a name, choose the mode, and get a shareable link.</p>
    <div class="form-grid">
      <div class="field">
        <label>Link Name</label>
        <input type="text" id="q-name" placeholder="e.g. Call of Duty Download"/>
      </div>
      <div class="field">
        <label>Destination URL</label>
        <input type="text" id="q-url" placeholder="https://romsfun.com/download/.../1"/>
      </div>
      <div class="field full">
        <label>Mode</label>
        <div class="mode-selector">
          <label class="mode-option selected" id="mode-smart">
            <input type="radio" name="mode" value="follow_redirect" checked/>
            <div class="mode-icon">🧠</div>
            <div>
              <strong>Smart Redirect</strong>
              <p>Server visits the URL with visitor's IP — generates an IP-specific download token for them. Use this for romsfun, and similar sites.</p>
            </div>
          </label>
          <label class="mode-option" id="mode-direct">
            <input type="radio" name="mode" value="static"/>
            <div class="mode-icon">↗</div>
            <div>
              <strong>Direct Redirect</strong>
              <p>Simply redirects the visitor to the URL. Use for links that don't need IP-based tokens.</p>
            </div>
          </label>
        </div>
      </div>
      <div class="field full">
        <label class="checkbox-label">
          <input type="checkbox" id="q-lander"/> Show a lander page (visitor clicks a button to get the link)
        </label>
      </div>
    </div>
    <button class="btn-primary" onclick="quickCreate()">Generate Link</button>

    <div id="quick-result" class="quick-result hidden">
      <p class="muted" style="margin-bottom:8px;">Your shareable link:</p>
      <div class="result-link-row">
        <span id="quick-link-url"></span>
        <button class="btn-ghost" onclick="copyQuickLink()">Copy</button>
      </div>
    </div>
  </div>

  <!-- ── All Links ── -->
  <div class="card">
    <h2>All Links</h2>
    <div id="campaigns-list"><p class="muted">Loading...</p></div>
  </div>

  <!-- Stats modal -->
  <div id="stats-modal" class="modal hidden">
    <div class="modal-box">
      <button class="modal-close" onclick="closeStats()">✕</button>
      <h2 id="stats-title">Stats</h2>
      <div id="stats-content"></div>
    </div>
  </div>
</div>

<script src="/js/admin.js"></script>
</body>
</html>
