<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= campaign.lander_title || campaign.name %></title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="lander-page">

<div class="lander-container">
  <div class="lander-card">
    <div class="lander-icon">⬇</div>
    <h1><%= campaign.lander_title || campaign.name %></h1>

    <% if (campaign.lander_description) { %>
      <p class="lander-desc"><%= campaign.lander_description %></p>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <div id="link-area">
      <button id="get-link-btn" class="btn-primary btn-large" onclick="getLink()">
        Get Download Link
      </button>
    </div>

    <p class="lander-note">Click the button above to get your personal download link.</p>
  </div>
</div>

<script>
  const SLUG = '<%= slug %>';

  async function getLink() {
    const btn = document.getElementById('get-link-btn');
    const area = document.getElementById('link-area');

    btn.disabled = true;
    btn.textContent = 'Loading…';

    try {
      const res = await fetch(`/r/${SLUG}/resolve`, { method: 'POST' });
      const data = await res.json();

      if (data.url) {
        // Open the download page immediately in a new tab
        const win = window.open(data.url, '_blank', 'noopener');

        area.innerHTML = `
          <div style="text-align:center;">
            <p style="font-size:1.1rem;font-weight:600;margin-bottom:12px;">
              ✅ Your download page is opening in a new tab!
            </p>
            <p class="lander-note">
              Wait for the countdown on that page (about 7 seconds),<br>
              then click the <strong>Download</strong> button that appears.
            </p>
            <a class="btn-primary btn-large" href="${escapeHtml(data.url)}" target="_blank" rel="noopener" style="margin-top:16px;display:inline-block;">
              Open Download Page Again
            </a>
          </div>
        `;

        // If popup was blocked, show a prominent manual link
        if (!win || win.closed) {
          area.innerHTML = `
            <div style="text-align:center;">
              <p class="alert-error" style="margin-bottom:12px;">
                Your browser blocked the popup. Click the button below to open the download page.
              </p>
              <a class="btn-primary btn-large" href="${escapeHtml(data.url)}" target="_blank" rel="noopener">
                ⬇ Open Download Page
              </a>
              <p class="lander-note" style="margin-top:14px;">
                Wait for the 7-second countdown, then click the Download button.
              </p>
            </div>
          `;
        }
      } else {
        throw new Error(data.error || 'Unknown error');
      }
    } catch (e) {
      area.innerHTML = `
        <p class="alert-error">${escapeHtml(e.message)}</p>
        <button class="btn-primary btn-large" onclick="location.reload()">Try Again</button>
      `;
    }
  }

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>
</body>
</html>
